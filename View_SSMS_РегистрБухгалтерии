USE ERP_Acc_Prod;

WITH
	Документы AS 
				(
				SELECT
					'Приобретение товаров и услуг' AS [Вид документа],
					ДокументПриобретения._IDRRef AS [ИДДокумента],
					ДокументПриобретения._Number AS [Номер документа],
					ДокументПриобретения._Fld27439RRef AS [ИДДоговора],
					ДокументПриобретения._Fld27413 AS [Сумма документа],
					ДокументПриобретения._Fld27470 AS [Знаменатель],
					'Кредит' AS [Вид движения]
				FROM
					_Document1255X1 AS ДокументПриобретения
				WHERE
					ДокументПриобретения._Posted = 0x01
				AND
					ДокументПриобретения._Fld27439RRef != 0x00000000000000000000000000000000
				
				UNION ALL

				SELECT
					'Реализация товаров и услуг' AS [Вид документа],
					РеализацияТоваровУслуг._IDRRef AS [ИДДокумента],
					РеализацияТоваровУслуг._Number AS [Номер документа],
					РеализацияТоваровУслуг._Fld30040RRef AS [ИДДоговора],
					РеализацияТоваровУслуг._Fld30021 AS [Сумма документа],
					CASE
					WHEN РеализацияТоваровУслуг._Fld30073 <= 0 THEN 1
					ELSE РеализацияТоваровУслуг._Fld30073
					END AS [Знаменатель],
					'Дебет' AS [Вид движения]
				FROM
					_Document1288X1 AS РеализацияТоваровУслуг
				WHERE
					_Posted = 0x01

				UNION ALL

				SELECT
					'Списание безналичных ДС' AS [Вид документа],
					ДокументСписания._IDRRef AS [ИДДокумента],
					ДокументСписания._Number AS [Номер документа],
					ОбъектРасчетов.ИДДоговора AS [ИДДоговора],
					ДокументСписания._Fld31927 AS [Сумма документа],
					Расшифровка._Fld32041 AS [Знаменатель],
					'Дебет' AS [Вид движения]
				FROM
					_Document1327X1 AS ДокументСписания
				JOIN
					_Document1327_VT32006X1 AS Расшифровка ON ДокументСписания._IDRRef = Расшифровка._Document1327_IDRRef
				JOIN
					(
					SELECT
						ОбъектРасчетов._IDRRef AS [ИДДокумента],
						ОбъектРасчетов._Fld66707_RRRef AS [ИДДоговора]
					FROM
						_Reference392 AS ОбъектРасчетов
					WHERE
						ОбъектРасчетов._Marked = 0x00
					AND
						ОбъектРасчетов._Fld66707_RRRef != 0x00000000000000000000000000000000
					) AS ОбъектРасчетов ON Расшифровка._Fld32039RRef = ОбъектРасчетов.ИДДокумента
				WHERE
					ДокументСписания._Posted = 0x01

				UNION ALL

				SELECT
					'Корректировка задолженности' AS [Вид документа],
					КорректировкаЗадолженности._IDRRef AS [ИДДокумента],
					КорректировкаЗадолженности._Number AS [Номер документа],
					ОбъектРасчетов.ИДДоговора AS [ИДДоговора],
					Реквизиты._Fld32088 AS [Сумма документа],
					1.0000 AS [Знаменатель],
					CASE
					WHEN ХозОперации._EnumOrder IN (335, 690) THEN 'Дебет'
					ELSE 'Кредит'
					END AS [Вид движения]
				 /* CASE ХозОперации._EnumOrder
					WHEN 335 THEN 'Начисление деб.задолженности' ---- + в платежи
					WHEN 339 THEN 'Начисление кред.задолженности' ---- + в расходы
					WHEN 681 THEN 'Списание безнадежной задолженоости за счет резервов по сомнительным долгам' ---- + в расходы
					WHEN 682 THEN 'Списание деб.задолженности' ---- + в расходы
					WHEN 690 THEN 'Списание кред.задолженности' ---- + в платежи
					END AS [Вид хоз.операции] */
				FROM
					_Document1328 AS КорректировкаЗадолженности
				JOIN
					_Document1328_VT32082 AS Реквизиты ON КорректировкаЗадолженности._IDRRef = Реквизиты._Document1328_IDRRef
				JOIN
					_Enum2627 AS ХозОперации ON КорректировкаЗадолженности._Fld32064RRef = ХозОперации._IDRRef
				JOIN
					(
					SELECT
						ОбъектРасчетов._IDRRef AS [ИДДокумента],
						ОбъектРасчетов._Fld66707_RRRef AS [ИДДоговора]
					FROM
						_Reference392 AS ОбъектРасчетов
					WHERE
						ОбъектРасчетов._Marked = 0x00
					AND
						ОбъектРасчетов._Fld66707_RRRef != 0x00000000000000000000000000000000
					) AS ОбъектРасчетов ON Реквизиты._Fld32090_RRRef = ОбъектРасчетов.ИДДокумента
				WHERE
					КорректировкаЗадолженности._Posted = 0x01
				AND
					NOT EXISTS
						(SELECT
							1
						FROM
							_Document1328
						WHERE
							КорректировкаЗадолженности._IDRRef = _Document1328._Fld86008RRef
						)

				UNION ALL

				SELECT
					'Поступление безналичных денежных средств' AS [Вид документа],
					ПоступлениеБС._IDRRef AS [ИДДокумента],
					ПоступлениеБС._Number AS [Номер документа],
					ПоступлениеБС._Fld25453_RRRef AS [ИДДоговора],
					ПоступлениеБС._Fld25420 AS [Сумма документа],
					CASE ПоступлениеБСРасшифровка._Fld25498
					WHEN 0 THEN 1
					ELSE ПоступлениеБСРасшифровка._Fld25498
					END AS [Знаменатель],
					'Кредит' AS [Вид движения]
				FROM
					_Document1229X1 AS ПоступлениеБС
				JOIN
					_Document1229_VT25467X1 AS ПоступлениеБСРасшифровка ON ПоступлениеБС._IDRRef = ПоступлениеБСРасшифровка._Document1229_IDRRef
				WHERE
					ПоступлениеБС._Posted = 0x01
				AND
					ПоступлениеБС._Fld25453_RRRef != 0x00000000000000000000000000000000
				AND
					ПоступлениеБСРасшифровка._LineNo25468 = 1

				UNION ALL

				SELECT
					'Ввод остатков взаиморасчетов' AS [Вид документа],
					ВводОстатковВзаиморасчетов._IDRRef AS [ИДДокумента],
					ВводОстатковВзаиморасчетов._Number AS [Номер документа],
					ВводОстатковРасшифровка._Fld4511_RRRef AS [ИДДоговора],
					ВводОстатковРасшифровка._Fld4513 AS [Сумма документа],
					1 AS [Знаменатель],
					CASE
					WHEN ХозОперации._EnumOrder IN (14,30) THEN 'Кредит'
					ELSE 'Дебет'
					END AS [Вид движения]
				FROM
					_Document889 AS ВводОстатковВзаиморасчетов
				JOIN
					_Enum2627 AS ХозОперации ON ВводОстатковВзаиморасчетов._Fld4498RRef = ХозОперации._IDRRef
				JOIN
					_Document889_VT4507 AS ВводОстатковРасшифровка ON ВводОстатковВзаиморасчетов._IDRRef = ВводОстатковРасшифровка._Document889_IDRRef
				WHERE
					ВводОстатковВзаиморасчетов._Posted = 0x01

				UNION ALL

				SELECT
					'Корректировка приобретения' AS [Вид документа],
					КорректировкаПриобретения._IDRRef AS [ИДДокумента],
					КорректировкаПриобретения._Number AS [Номер документа],
					КорректировкаПриобретения._Fld15027RRef AS [ИДДоговора],
					CASE
					WHEN Расхождения.[Сумма документа] < 0 THEN Расхождения.[Сумма документа] * -1
					ELSE Расхождения.[Сумма документа]
					END AS [Сумма документа],
					CASE
					WHEN КорректировкаПриобретения._Fld15063 <= 0 THEN 1
					ELSE КорректировкаПриобретения._Fld15063
					END AS [Знаменатель],
					CASE
					WHEN Расхождения.[Сумма документа] < 0 THEN 'Дебет'
					ELSE 'Кредит'
					END AS [Вид движения]
				FROM
					_Document1067X1 AS КорректировкаПриобретения
				LEFT JOIN
					(
					SELECT
						Расхождения._Document1067_IDRRef AS [ИДДокумента],
						SUM(_Fld15122) AS [Сумма документа]
					FROM
						_Document1067_VT15107X1 AS Расхождения
					GROUP BY
						Расхождения._Document1067_IDRRef
					) AS Расхождения ON КорректировкаПриобретения._IDRRef = Расхождения.ИДДокумента
				WHERE
					КорректировкаПриобретения._Posted = 0x01

				UNION ALL

				SELECT
					'Корректировка реализации' AS [Вид документа],
					КорректировкаРеализации._IDRRef AS [ИДДокумента],
					КорректировкаРеализации._Number AS [Номер документа],
					КорректировкаРеализации._Fld15196RRef AS [ИДДоговора],
					CASE
					WHEN Расхождения.[Сумма документа] < 0 THEN Расхождения.[Сумма документа] * -1
					ELSE Расхождения.[Сумма документа]
					END AS [Сумма документа],
					CASE
					WHEN КорректировкаРеализации._Fld15242 <= 0 THEN 1
					ELSE КорректировкаРеализации._Fld15242
					END AS [Знаменатель],
					CASE
					WHEN Расхождения.[Сумма документа] < 0 THEN 'Кредит'
					ELSE 'Дебет'
					END [Вид движения]
				FROM
					_Document1068X1 AS КорректировкаРеализации
				JOIN
					(
					SELECT
						Расхождения._Document1068_IDRRef AS [ИДДокумента],
						SUM(Расхождения._Fld15288) AS [Сумма документа]
					FROM
						_Document1068_VT15275X1 AS Расхождения
					GROUP BY
						Расхождения._Document1068_IDRRef
					) AS Расхождения ON КорректировкаРеализации._IDRRef = Расхождения.ИДДокумента
				WHERE
					КорректировкаРеализации._Posted = 0x01
				
				UNION ALL

				SELECT
					'Взаимозачет_Дебитор' AS [ВидДокумента],
					ВзаимозачетЗадолженностиДебитор._Document914_IDRRef AS [ИДДокумента],
					NULL AS [Номер документа],
					ОбъектРасчетов.ИДДоговора,
					SUM(ВзаимозачетЗадолженностиДебитор._Fld6012) AS [Сумма документа],
					1.0000 AS [Знаменатель],
					'Кредит' AS [Вид движения]
				FROM
					_Document914_VT6006 AS ВзаимозачетЗадолженностиДебитор
				JOIN
					_Document914 AS ДокументВзаимозачета ON ВзаимозачетЗадолженностиДебитор._Document914_IDRRef = ДокументВзаимозачета._IDRRef
				JOIN
					(
					SELECT
						ОбъектРасчетов._IDRRef AS [ИДДокумента],
						ОбъектРасчетов._Fld66707_RRRef AS [ИДДоговора]
					FROM
						_Reference392 AS ОбъектРасчетов
					WHERE
						ОбъектРасчетов._Marked = 0x00
					AND
						ОбъектРасчетов._Fld66707_RRRef != 0x00000000000000000000000000000000
					) AS ОбъектРасчетов ON ВзаимозачетЗадолженностиДебитор._Fld6018RRef = ОбъектРасчетов.ИДДокумента
				WHERE
					ДокументВзаимозачета._Posted = 0x01
				GROUP BY
					ВзаимозачетЗадолженностиДебитор._Document914_IDRRef,
					ОбъектРасчетов.ИДДоговора

				UNION ALL

				SELECT
					'Взаимозачет_Кредитор' AS [ВидДокумента],
					ВзаимозачетЗадолженностиКредитор._Document914_IDRRef AS [ИДДокумента],
					NULL AS [Номер документа],
					ОбъектРасчетов.ИДДоговора,
					SUM(ВзаимозачетЗадолженностиКредитор._Fld6027) AS [Сумма документа],
					1.0000 AS [Знаменатель],
					'Дебет' AS [Вид движения]
				FROM
					_Document914_VT6021 AS ВзаимозачетЗадолженностиКредитор
				JOIN
					_Document914 AS ДокументВзаимозачета ON ВзаимозачетЗадолженностиКредитор._Document914_IDRRef = ДокументВзаимозачета._IDRRef
				JOIN
					(
					SELECT
						ОбъектРасчетов._IDRRef AS [ИДДокумента],
						ОбъектРасчетов._Fld66707_RRRef AS [ИДДоговора]
					FROM
						_Reference392 AS ОбъектРасчетов
					WHERE
						ОбъектРасчетов._Marked = 0x00
					AND
						ОбъектРасчетов._Fld66707_RRRef != 0x00000000000000000000000000000000
					) AS ОбъектРасчетов ON ВзаимозачетЗадолженностиКредитор._Fld6033RRef = ОбъектРасчетов.ИДДокумента
				WHERE
					ДокументВзаимозачета._Posted = 0x01
				GROUP BY
					ВзаимозачетЗадолженностиКредитор._Document914_IDRRef,
					ОбъектРасчетов.ИДДоговора
				),

	ДокументСторно AS
				(
				SELECT
					ДокументСторно._Fld33262_RRRef AS [СторнируемыйДокумент]
				FROM
					_Document1348X1 AS ДокументСторно
				WHERE
					ДокументСторно._Posted = 0x01
				),

	Договора AS
				(
				SELECT
					Договора._IDRRef AS [ИДДоговора],
					Организация._Description AS [Организация],
					Подразделение.Подразделение,
					Проект._Description AS [Проект],
					Контрагент._Description AS [Контрагент],
					Договора._Description AS [Договор],
					Договора._Fld61563 AS [Сумма договора]
				FROM
					_Reference196X1 AS Договора
				JOIN
					(
					SELECT
						Подразделение._IDRRef AS [ИДПодразделения],
						Подразделение._Description AS [Подразделение]
					FROM
						_Reference513X1 AS Подразделение
					/* WHERE
						Подразделение._Description LIKE '%ДПЖ%'
					OR
						Подразделение._Description LIKE '%Живк%' */ ---- СРЕЗ ПО ПОДРАЗДЕЛЕНИЮ ДОГОВОРОВ
					) AS Подразделение ON Договора._Fld61547RRef = Подразделение.ИДПодразделения
				JOIN
					_Reference577X1 AS Проект ON Договора._Fld80476RRef = Проект._IDRRef ---- ОБЯЗАТЕЛЬНОЕ НАЛИЧИЕ ПРОЕКТА
				JOIN
					_Reference410X1 AS Организация ON Договора._Fld61538RRef = Организация._IDRRef
				JOIN
					_Reference324X1 AS Контрагент ON Договора._Fld61539RRef = Контрагент._IDRRef
				WHERE
					Договора._Marked = 0x00
				)
				

SELECT
	Договора.Организация,
	Договора.Подразделение,
	Договора.Проект,
	Договора.Контрагент,
	Договора.Договор,
	Договора.[Сумма договора],
	CAST(SUM(CASE
		WHEN Документы_1.[Вид движения] = 'Кредит' THEN Документы_1.[Сумма документа] / Документы_1.Знаменатель
		ELSE NULL
		END) / IIF(Договора.[Сумма договора] = 0, NULL, Договора.[Сумма договора]) * 100 AS decimal(15,2)) AS [Освоение договора],
	CAST(SUM(CASE
		WHEN Документы_1.[Вид движения] = 'Дебет' THEN Документы_1.[Сумма документа] / Документы_1.Знаменатель
		ELSE NULL
		END) AS decimal(20,2)) AS [Оплачено],
	CAST(SUM(CASE
		WHEN Документы_1.[Вид движения] = 'Кредит' THEN Документы_1.[Сумма документа] / Документы_1.Знаменатель
		ELSE NULL
		END) AS decimal(20,2)) AS [Освоено],
	CAST(SUM(CASE
		WHEN Документы_1.[Вид движения] = 'Кредит' THEN Документы_1.[Сумма документа] / Документы_1.Знаменатель
		ELSE NULL
		END) - SUM(CASE
					WHEN Документы_1.[Вид движения] = 'Дебет' THEN Документы_1.[Сумма документа] / Документы_1.Знаменатель
					ELSE NULL
					END) AS decimal(20,2)) AS [Остаток оплат]
FROM
	Договора
JOIN
	(
	SELECT
		*
	FROM
		Документы
	WHERE
		NOT EXISTS 
				(
				SELECT
					*
				FROM
					ДокументСторно
				WHERE
					Документы.ИДДокумента = ДокументСторно.СторнируемыйДокумент
				)
	) AS Документы_1 ON Договора.ИДДоговора = Документы_1.ИДДоговора
WHERE
	Договора.Контрагент NOT LIKE '%Русагро%'
GROUP BY
	Договора.Организация,
	Договора.Подразделение,
	Договора.Проект,
	Договора.Контрагент,
	Договора.Договор,
	Договора.[Сумма договора]
HAVING
	CAST(SUM(CASE
		WHEN Документы_1.[Вид движения] = 'Кредит' THEN Документы_1.[Сумма документа] / Документы_1.Знаменатель
		ELSE NULL
		END) - SUM(CASE
					WHEN Документы_1.[Вид движения] = 'Дебет' THEN Документы_1.[Сумма документа] / Документы_1.Знаменатель
					ELSE NULL
					END) AS decimal(20,2)) >= 0.1
ORDER BY
	Договора.Организация,
	Договора.Подразделение,
	Договора.Контрагент
